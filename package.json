{
  "name": "aviation-blockchain-storage",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "setup": "npm --prefix backend install && npm --prefix frontend install",
    "compile": "npm --prefix backend run compile",
    "clean": "npm --prefix backend run clean",
    "test": "npm --prefix backend run test",
    "check": "npm run test && npm run frontend:lint && npm run frontend:build",
    "node": "npm run ganache",
    "deploy:localhost": "npm --prefix backend run deploy:localhost",
    "seed:localhost": "npm --prefix backend run seed:localhost",
    "deploy:ganache": "npm --prefix backend run deploy:ganache",
    "seed:ganache": "npm --prefix backend run seed:ganache",
    "ganache": "node backend/scripts/ganache.js",
    "app:dev": "node backend/scripts/wait_ganache.js && npm run compile && npm run deploy:ganache && npm run seed:ganache && npm run frontend:dev",
    "dev": "concurrently -k -n chain,app \"npm run ganache\" \"npm run app:dev\"",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:lint": "npm --prefix frontend run lint",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:preview": "npm --prefix frontend run preview"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "ganache": "^7.9.2",
    "wait-on": "^8.0.5"
  }
}